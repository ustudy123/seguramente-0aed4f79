# Variáveis de ambiente do projeto YourEyes
# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.

# URL pública do projeto Supabase (encontrado em Project Settings > API)
SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_URL="https://<project-id>.supabase.co"

# Anon/public key do projeto Supabase (chave pública, pode ir no frontend)
SUPABASE_PUBLISHABLE_KEY="<anon-key>"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key>"

# Project ID do Supabase (usado em algumas construções de URL)
VITE_SUPABASE_PROJECT_ID="<project-id>"

# URL da aplicação (muda entre preview, publicação e local)
VITE_APP_URL="https://seguramente.lovable.app"
